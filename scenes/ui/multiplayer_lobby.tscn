[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/multiplayer_lobby.gd" id="1_lobby"]
[ext_resource type="Theme" path="res://resources/theme/game_theme.tres" id="2_theme"]

[node name="MultiplayerLobby" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2_theme")
script = ExtResource("1_lobby")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.15, 0.22, 0.32, 1)

[node name="Panel" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -220.0
offset_top = -200.0
offset_right = 220.0
offset_bottom = 200.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Panel"]
layout_mode = 2
theme_override_font_sizes/font_size = 36
text = "Fishing Life"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="Panel"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Multijugador (hasta 4)"
horizontal_alignment = 1

[node name="AddressField" type="LineEdit" parent="Panel"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "IP del host (ej. 100.64.0.5 Tailscale)"

[node name="PortField" type="LineEdit" parent="Panel"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Puerto (4242)"

[node name="HostButton" type="Button" parent="Panel"]
unique_name_in_owner = true
layout_mode = 2
text = "Crear partida (Host)"

[node name="JoinButton" type="Button" parent="Panel"]
unique_name_in_owner = true
layout_mode = 2
text = "Unirse"

[node name="SoloButton" type="Button" parent="Panel"]
unique_name_in_owner = true
layout_mode = 2
text = "Jugar solo"

[node name="StatusLabel" type="Label" parent="Panel"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 16
text = "Host: crea partida. Join: IP del host."
autowrap_mode = 2

[node name="Hint" type="Label" parent="Panel"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.75, 0.82, 0.9, 1)
text = "Online sin Steam: instala Tailscale, el host comparte su IP 100.x.x.x y el puerto 4242."
autowrap_mode = 2

[connection signal="pressed" from="Panel/HostButton" to="." method="_on_host_pressed"]
[connection signal="pressed" from="Panel/JoinButton" to="." method="_on_join_pressed"]
[connection signal="pressed" from="Panel/SoloButton" to="." method="_on_solo_pressed"]
